# ══════════════════════════════════════════════════
# Du'a Generator — Environment Variables
# Copy this to .env and fill in your values
# ══════════════════════════════════════════════════

# ── AI API (choose one) ──
# OpenAI
# ANTHROPIC_API_KEY=s
# OR Anthropic


# Which provider to use: "openai" or "anthropic"
AI_PROVIDER=anthropic

# Anthropic model — change to test different models:
#   claude-opus-4-6       (best quality, $5/$25 per MTok)
#   claude-sonnet-4-6     (balanced, $3/$15 per MTok)
#   claude-haiku-4-5-20251001  (fastest/cheapest, $1/$5 per MTok)
ANTHROPIC_MODEL=claude-opus-4-6

# ── Email (for du'a delivery) ──
# Gmail example: use an App Password (not your regular password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=support@mydua.ai
SMTP_PASSWORD=slif vqgo uomw dtez
SMTP_FROM_NAME=Du'a Generator
SMTP_FROM_EMAIL=support@mydua.ai

# ── App Settings ──
APP_BASE_URL=http://localhost:8000
SECRET_KEY=change-this-to-a-random-string-at-least-32-chars

# ── Stripe (Support Us + Gift Payments) ──
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...your-key-here...
STRIPE_PUBLISHABLE_KEY=pk_test_...your-key-here...

# ── Twilio (SMS Gift Delivery — $2.49/gift) ──
# Get these from https://console.twilio.com
# Leave blank to disable SMS gifting
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Lob (Postcard Gift Delivery — $10.99/gift) ──
# Get these from https://dashboard.lob.com
# Leave blank to disable postcard gifting
LOB_API_KEY=
LOB_FROM_NAME=mydua.ai
LOB_FROM_ADDRESS_LINE1=
LOB_FROM_CITY=
LOB_FROM_STATE=
LOB_FROM_ZIP=

# ── ElevenLabs (AI Voice — "Listen" button) ──
# Get API key from https://elevenlabs.io — free tier: 10,000 chars/month
# Leave blank to use free browser text-to-speech instead
ELEVENLABS_API_KEY=
# Voice ID — default "Rachel" is warm and reverent. Browse voices at elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Optional ──
# Set to "production" to disable debug mode
APP_ENV=development
