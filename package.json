{
  "name": "mydua-ai-mobile",
  "version": "2.0.0",
  "description": "MyDua.AI — Personalized Islamic supplications (mobile app)",
  "private": true,
  "scripts": {
    "start": "echo 'Backend runs separately via uvicorn. This package is for the Capacitor mobile shell only.'",
    "cap:init": "npx cap init 'MyDua.AI' 'ai.mydua.app' --web-dir static",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "cap:build:ios": "npx cap sync ios && npx cap open ios",
    "cap:build:android": "npx cap sync android && npx cap open android",
    "icons:generate": "npx capacitor-assets generate --iconBackgroundColor '#0a0a0f' --splashBackgroundColor '#0a0a0f'"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/network": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capacitor/geolocation": "^6.0.0",
    "@capacitor/browser": "^6.0.0",
    "capacitor-background-audio": "^1.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/assets": "^3.0.0"
  }
}
